---
import type { ExchangeRate } from "../utils/api";
import type { RateStats } from "../utils/statistics";
import { formatBs } from "../utils/api";

interface Props {
  rates: ExchangeRate[];
  stats: RateStats;
}

const { rates, stats } = Astro.props;
const periodOptions = [7, 15, 30];
const chartPayload = JSON.stringify(stats.histories);
const averageVolatility = Math.round(
  stats.variations.reduce((sum, variation) => sum + variation.volatility30, 0) /
    stats.variations.length,
);
function obtenerFechaCorta() {
  const fecha = new Date();
  const dia = String(fecha.getDate()).padStart(2, "0");
  const mes = String(fecha.getMonth() + 1).padStart(2, "0");
  const anio = fecha.getFullYear();

  return `${dia}/${mes}/${anio}`;
}
---

<section class="stats-section">
  <div class="container">
    <div class="cards-grid">
      {
        stats.variations
          .filter(
            (variation) =>
              variation.code === "USD" ||
              variation.code === "USDT" ||
              variation.code === "EUR",
          )
          .map((variation) => (
            <article class="stat-card">
              <div class="stat-card-title">{variation.name} - Hoy {obtenerFechaCorta()}</div>
               
              <div class="stat-card-value">
                {formatBs(variation.currentRate)}
              </div>
              <div class="stat-card-meta">
                Variación con respecto a la tasa anterior
              </div>
              <div
                class={`stat-card-change ${variation.variation >= 0 ? "positive" : "negative"}`}
              >
                {variation.formattedVariation} (
                {formatBs(variation.currentRate - variation.previousRate)})
              </div>

              <div class="stat-card-line">
                <span>Tasa anterior:</span>
                <strong>{formatBs(variation.previousRate)}</strong>
              </div>
              <div class="stat-card-line">
                <span>Tasa Min Ultimos 30d:</span>
                <strong>{formatBs(variation.min30)} </strong>
              </div>
              <div class="stat-card-line">
                <span>Tasa Max Ultimos 30d:</span>
                <strong>{formatBs(variation.max30)}</strong>
              </div>
            </article>
          ))
      }
    </div>
    <div class="grid grid-cols-2 mb-8">
      <article class="stat-card highlight-card">
        <h2 class="stat-card-title">
          Brecha cambiaria en Venezuela USDT / Dólar BCV
        </h2>
        <div class="stat-card-value">{formatBs(stats.spreadAmount)}</div>
        <div
          class={`stat-card-change ${stats.spreadAmount >= 0 ? "positive" : "negative"}`}
        >
          {stats.spreadPercent >= 0 ? "+" : ""}{stats.spreadPercent.toFixed(2)}%
        </div>
      </article>
      <article class="stat-card trend-card highlight-card">
        <h2 class="stat-card-title">Tendencia general acumulada a 30 días</h2>
        <p class="stat-card-meta">
          Cambios promedio acumulados en las tres tasas tomando en cuenta la máxima tasa y la mínima en cada una en los últimos 30 días.
        </p>
        <div class="stat-card-value">{stats.trendLabel}</div>
        <div
          class={`stat-card-change ${stats.trendScore >= 0 ? "positive" : "negative"}`}
        >
          {stats.trendScore >= 0 ? "+" : ""}{stats.trendScore.toFixed(2)}%
        </div>
        <div class="stat-card-line">
          <span>Interpretación:</span>
          <strong
            >{
              stats.trendLabel === "Estable"
                ? "Las tasas oscilan sin tendencia definida"
                : stats.trendLabel === "Alcista"
                  ? "Subida general"
                  : "Descenso general"
            }</strong
          >
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .stats-section {
    padding: var(--spacing-2xl) 0;
  }

  .section-intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
  }

  .section-intro h2 {
    margin: 0;
    font-size: 2rem;
  }

  .section-intro p {
    color: var(--color-text-secondary);
    max-width: 720px;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
  }

  .stat-card,
  .highlight-card {
    background: var(--surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--spacing-lg);
    box-shadow: var(--shadow-sm);
  }

  .stat-card-title {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: var(--spacing-sm);
  }

  .stat-card-value {
    font-size: 1.7rem;
    font-weight: 800;
    margin-bottom: var(--spacing-sm);
  }

  .stat-card-change {
    font-weight: 700;
    margin-bottom: var(--spacing-sm);
  }

  .stat-card-change.positive {
    color: #abda40;
  }

  .stat-card-change.negative {
    color: #e93030;
  }

  .stat-card-meta,
  .stat-card-line {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    margin-top: 0.5rem;
  }

  .stat-card-line {
    display: flex;
    justify-content: space-between;
    gap: var(--spacing-md);
  }

  .highlight-card {
    grid-column: span 1;
    background: rgba(224, 228, 233, 0.08);
  }

  @media (max-width: 1200px) {
    .cards-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .highlight-card {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .section-intro,
    .history-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .cards-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
