---
import Layout from "../layouts/Layout.astro";

import ProfitCalculator from "../components/ProfitCalculator.astro";

import { getAllRates } from "../utils/api";

const rates = await getAllRates();
---

<Layout
  metatitle="Calculadora de Precios en Venezuela - Dólar BCV, Euro y USDT"
  metadescrip="Ideal para comerciantes. Calcula el precio de venta de tu producto con margen de ganancia en diferentes divisas usando las tasas actualizadas del Dólar BCV, Euro y USDT."
  slug="calculadora-precios/"
>
  <section class="legal-page">
    <div class="container">
      <ProfitCalculator rates={rates} />
    </div>
  </section>
</Layout>

<style>
  .legal-page {
    padding: var(--spacing-2xl) 0;
    min-height: 70vh;
  }

  .container h1 {
    font-size: 2.5rem;
    margin-bottom: var(--spacing-sm);
    text-align: center;
  }

  .legal-content h2 {
    font-size: 1.5rem;
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-md);
    color: var(--color-accent-primary);
  }

  .legal-content p {
    line-height: 1.8;
    margin-bottom: var(--spacing-md);
  }

  .legal-content ul {
    margin-left: var(--spacing-xl);
    margin-bottom: var(--spacing-md);
  }

  .legal-content li {
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: var(--spacing-xs);
  }
</style>
